# Production on EC2 — /opt/dcb-backend/.env
# Do NOT set AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY (use EC2 instance role).

NODE_ENV=production
PORT=3000
HOST=0.0.0.0

DATABASE_URL=postgresql://dcb_admin:FROM_TERRAFORM_OUTPUT@RDS_ENDPOINT:5432/dcb_ap?schema=public
REDIS_URL=redis://ELASTICACHE_PRIMARY_ENDPOINT:6379

JWT_SECRET=
JWT_REFRESH_SECRET=

CORS_ORIGINS=https://your-cloudfront-domain.cloudfront.net

AWS_REGION=ap-south-2
S3_EXPORTS_BUCKET=waqf-dcb-exports-ap-south-2
S3_RECEIPTS_BUCKET=waqf-dcb-receipts-ap-south-2
