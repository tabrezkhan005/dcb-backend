NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Docker Compose (docker compose up -d) — Postgres on host port 5433
DATABASE_URL=postgresql://postgres:dcb_local_dev@localhost:5433/dcb_ap?schema=public
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-use-at-least-32-characters-long-secret
JWT_REFRESH_SECRET=change-me-use-another-32-characters-minimum

# Expo dev server origins (add your LAN IP for physical devices)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# AWS (ap-south-2) — S3 only; used by export + receipt workers
AWS_REGION=ap-south-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_EXPORTS_BUCKET=waqf-dcb-exports-ap-south-2
S3_RECEIPTS_BUCKET=waqf-dcb-receipts-ap-south-2

# Optional — not used by current backend code
EXPO_ACCESS_TOKEN=
